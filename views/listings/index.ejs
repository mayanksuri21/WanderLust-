<% layout("layouts/boilerplate") %>

<section class="home-hero reveal-on-scroll">
    <div class="home-hero__content">
        <p class="eyebrow">Premium stays, handpicked for your next escape</p>
        <h1>Find a place that makes the trip feel effortless.</h1>
        <p class="hero-copy">Browse remarkable homes, cabins, villas, and city apartments with a cleaner, faster travel experience.</p>
        <div class="hero-actions">
            <a href="#listingGrid" class="btn btn-primary app-btn">Explore stays</a>
            <a href="/listings/new" class="btn btn-light app-btn">Host a home</a>
        </div>
    </div>
    <div class="home-hero__panel">
        <div>
            <span class="hero-stat"><%= allListings.length %>+</span>
            <span class="hero-label">curated listings</span>
        </div>
        <div>
            <span class="hero-stat">18%</span>
            <span class="hero-label">tax view toggle</span>
        </div>
        <div>
            <span class="hero-stat">24/7</span>
            <span class="hero-label">travel-ready browsing</span>
        </div>
    </div>
</section>

<section class="filters-bar reveal-on-scroll" aria-label="Listing filters">
    <div class="filter active">
        <i class="fa-solid fa-fire"></i>
        <span>Trending</span>
    </div>
    <div class="filter">
        <i class="fa-solid fa-bed"></i>
        <span>Rooms</span>
    </div>
    <div class="filter">
        <i class="fa-solid fa-mountain-city"></i>
        <span>Iconic Cities</span>
    </div>
    <div class="filter">
        <i class="fa-solid fa-mountain"></i>
        <span>Mountains</span>
    </div>
    <div class="filter">
        <i class="fa-brands fa-fort-awesome"></i>
        <span>Castles</span>
    </div>
    <div class="filter">
        <i class="fa-solid fa-person-swimming"></i>
        <span>Pools</span>
    </div>
    <div class="filter">
        <i class="fa-solid fa-campground"></i>
        <span>Camping</span>
    </div>
    <div class="filter">
        <i class="fa-solid fa-snowflake"></i>
        <span>Arctic</span>
    </div>
    <div class="tax-toggle">
        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Show taxes</label>
        </div>
    </div>
</section>

<section class="listing-section" id="listingGrid">
    <div class="section-heading reveal-on-scroll">
        <div>
            <p class="eyebrow">Explore stays</p>
            <h2>Popular homes right now</h2>
        </div>
        <p class="muted-text" id="listingCount"><%= allListings.length %> stays available</p>
    </div>

    <div class="listing-grid">
        <% for (let listing of allListings) { %>
            <a href="/listings/<%=listing._id%>" class="listing-link reveal-on-scroll listing-search-item" data-title="<%= listing.title %>" data-location="<%= listing.location %>" data-country="<%= listing.country %>">
                <article class="listing-card">
                    <div class="listing-img-wrap">
                        <img src="<%= (listing.image && listing.image.url) ? listing.image.url : 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=900&q=80' %>"
                            class="card-img-top" alt="<%= listing.title %>" loading="lazy" />
                        <span class="listing-badge"><i class="fa-solid fa-star"></i> Guest favorite</span>
                    </div>
                    <div class="card-body">
                        <div>
                            <h3 class="listing-title"><%=listing.title%></h3>
                            <p class="listing-location"><i class="fa-solid fa-location-dot"></i> <%=listing.location%>, <%=listing.country%></p>
                        </div>
                        <p class="listing-price">&#8377;<%=listing.price.toLocaleString("en-IN")%><span>/ night</span></p>
                        <p class="tax-info">Includes estimated GST at checkout</p>
                    </div>
                </article>
            </a>
        <% } %>
    </div>
    <div class="empty-state" id="emptyListings" hidden>
        <i class="fa-regular fa-compass"></i>
        <h3>No matching stays found</h3>
        <p>Try another city, country, or listing name.</p>
    </div>
</section>

<script>
    const taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click", () => {
        document.querySelectorAll(".tax-info").forEach((info) => {
            info.classList.toggle("is-visible", taxSwitch.checked);
        });
    });
</script>
