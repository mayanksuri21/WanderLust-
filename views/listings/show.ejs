<% layout("layouts/boilerplate") %>
<script>
    const mapToken = "<%= process.env.MAP_TOKEN %>"
    const listing = <%- JSON.stringify(listing) %>;
</script>

<section class="show-page">
    <div class="show-hero reveal-on-scroll">
        <div class="show-copy">
            <p class="eyebrow"><i class="fa-solid fa-location-dot"></i> <%=listing.location%>, <%=listing.country%></p>
            <h1><%=listing.title%></h1>
            <p><%=listing.description%></p>
        </div>
        <div class="show-image-wrap">
            <img src="<%= listing.image.url %>" class="show-img" alt="<%= listing.title %>">
        </div>
    </div>

    <div class="show-layout">
        <article class="show-main reveal-on-scroll">
            <div class="detail-block">
                <div>
                    <p class="eyebrow">Hosted by</p>
                    <h2><%=listing.owner.username%></h2>
                </div>
                <p class="muted-text">Exact address and arrival details are shared after booking confirmation.</p>
            </div>

            <% if(currUser && currUser._id.equals(listing.owner._id)){ %>
                <div class="owner-actions">
                    <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark app-btn"><i class="fa-regular fa-pen-to-square"></i> Edit listing</a>
                    <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
                        <button class="btn btn-outline-danger app-btn"><i class="fa-regular fa-trash-can"></i> Delete</button>
                    </form>
                </div>
            <% } %>

            <% if(currUser){ %>
                <section class="review-form-card reveal-on-scroll">
                    <div class="section-heading compact">
                        <div>
                            <p class="eyebrow">Share your stay</p>
                            <h2>Leave a review</h2>
                        </div>
                    </div>
                    <form method="POST" action="/listings/<%=listing._id%>/reviews" novalidate class="needs-validation">
                        <div class="mb-3">
                            <label for="rating" class="form-label">Rating</label>
                            <fieldset class="starability-slot">
                                <legend>First rating:</legend>
                                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                <label for="first-rate1" title="Terrible">1 star</label>
                                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                <label for="first-rate2" title="Not good">2 stars</label>
                                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                <label for="first-rate3" title="Average">3 stars</label>
                                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                <label for="first-rate4" title="Very good">4 stars</label>
                                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                <label for="first-rate5" title="Amazing">5 stars</label>
                            </fieldset>
                        </div>
                        <div class="mb-3">
                            <label for="comment" class="form-label">Comments</label>
                            <textarea name="review[comments]" id="comment" rows="5" class="form-control" placeholder="What made this stay memorable?" required></textarea>
                            <div class="invalid-feedback">Please add some comments for review</div>
                        </div>
                        <button class="btn btn-primary app-btn" type="submit">Submit review</button>
                    </form>
                </section>
            <% } %>

            <% if(listing.reviews.length > 0) { %>
                <section class="reviews-section reveal-on-scroll">
                    <div class="section-heading compact">
                        <div>
                            <p class="eyebrow">Guest notes</p>
                            <h2>All reviews</h2>
                        </div>
                    </div>
                    <div class="reviews-grid">
                        <% for(review of listing.reviews) { %>
                            <article class="review-card">
                                <div class="review-card__top">
                                    <span class="avatar-pill">@<%= review.author.username%></span>
                                    <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                                </div>
                                <p><%= review.comments %></p>
                                <form method="POST" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                                    <button class="btn btn-sm btn-outline-dark">Delete</button>
                                </form>
                            </article>
                        <% } %>
                    </div>
                </section>
            <% } %>
        </article>

        <aside class="booking-panel reveal-on-scroll">
            <p class="eyebrow">From</p>
            <h2>&#8377;<%=listing.price.toLocaleString("en-IN")%><span>/ night</span></h2>
            <div class="booking-line">
                <span>Location</span>
                <strong><%=listing.location%></strong>
            </div>
            <div class="booking-line">
                <span>Country</span>
                <strong><%=listing.country%></strong>
            </div>
            <a href="#map" class="btn btn-dark app-btn w-100">View on map</a>
        </aside>
    </div>

    <section class="map-section reveal-on-scroll">
        <div class="section-heading compact">
            <div>
                <p class="eyebrow">Neighborhood</p>
                <h2>Where you'll be</h2>
            </div>
        </div>
        <div id="map"></div>
    </section>
</section>

<script src="/js/map.js"></script>
