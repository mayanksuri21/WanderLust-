<% layout("layouts/boilerplate") %>

<section class="features-showcase">
  <header class="features-hero reveal-on-scroll">
    <p class="eyebrow"><i class="bi bi-stars"></i> Platform Capabilities</p>
    <h1>Engineered for Seamless Travel</h1>
    <p>
      WanderLust brings discovery, planning, hosting, and trusted community feedback into one
      polished travel experience built for confident decisions.
    </p>
  </header>

  <div class="row row-cols-1 row-cols-md-2 g-4 features-grid">
    <div class="col reveal-on-scroll">
      <article class="feature-card h-100">
        <div class="feature-icon">
          <i class="bi bi-houses"></i>
        </div>
        <div>
          <h2>Core Booking Engine</h2>
          <p>
            Browse premium, handpicked stays, cabins, and villas across global destinations with
            a refined discovery flow built for fast comparison.
          </p>
        </div>
      </article>
    </div>

    <div class="col reveal-on-scroll">
      <article class="feature-card h-100">
        <div class="feature-icon">
          <i class="bi bi-magic"></i>
        </div>
        <div>
          <h2>AI Travel Planner</h2>
          <p>
            Generate advanced trip itineraries tailored to budget, destination, preferences,
            travel style, and the pace of each journey.
          </p>
        </div>
      </article>
    </div>

    <div class="col reveal-on-scroll">
      <article class="feature-card h-100">
        <div class="feature-icon">
          <i class="bi bi-shield-check"></i>
        </div>
        <div>
          <h2>Authenticated Hosting Pipeline</h2>
          <p>
            Securely onboard properties through protected host access, interactive form
            verification, and image uploads for rich listing presentation.
          </p>
        </div>
      </article>
    </div>

    <div class="col reveal-on-scroll">
      <article class="feature-card h-100">
        <div class="feature-icon">
          <i class="bi bi-star-half"></i>
        </div>
        <div>
          <h2>Trusted Reviews System</h2>
          <p>
            Give logged-in community members full CRUD capability to leave star ratings and
            thoughtful feedback after exploring a stay.
          </p>
        </div>
      </article>
    </div>
  </div>

  <section class="features-cta reveal-on-scroll">
    <h2>Start exploring WanderLust today.</h2>
    <p>Discover stays, compare destinations, and experience the full platform in action.</p>
    <a href="/listings" class="btn btn-primary app-btn btn-lg">
      <i class="bi bi-compass"></i> Explore Listings
    </a>
  </section>
</section>
